---
import Layout from "../../layouts/Layout.astro";
import ActaForm from "../../components/ActaForm";
import { db } from "../../lib/db.js";

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/login", 302);
}

// Get selected session ID from query params
const selectedSessionId = Astro.url.searchParams.get("session");

// Query sessions list based on career scope
let sessionsQuery = "";
let sessionsParams: any[] = [];

if (user.role === "jefe_carrera") {
  sessionsQuery = `
    SELECT * FROM sessions 
    WHERE career = ? 
    ORDER BY date DESC, time DESC
  `;
  sessionsParams = [user.career];
} else {
  sessionsQuery = `
    SELECT * FROM sessions 
    ORDER BY date DESC, time DESC
  `;
}

const allSessions = db.prepare(sessionsQuery).all(...sessionsParams) as any[];

// Get last 3 sessions
const last3Sessions = allSessions.slice(0, 3);
// Remaining sessions for "older" search selector
const olderSessions = allSessions.slice(3);

let activeSession = null;
let invitedStudents: any[] = [];
let existingAgreements: string[] = [];

if (selectedSessionId) {
  // Load selected session details
  activeSession = db
    .prepare("SELECT * FROM sessions WHERE id = ?")
    .get(selectedSessionId) as any;

  if (activeSession) {
    // Verify scope permissions
    if (user.role === "jefe_carrera" && activeSession.career !== user.career) {
      activeSession = null; // Deny access
    } else {
      // Parse agenda JSON
      activeSession.agendaParsed = JSON.parse(activeSession.agenda || "[]");

      // Load invited students with attendance status
      invitedStudents = db
        .prepare(
          `
        SELECT s.id, s.enrollment, s.full_name, s.career, s.grade, s.group_letter, s.role, i.whatsapp_sent, i.attended
        FROM students s
        JOIN invites i ON s.id = i.student_id
        WHERE i.session_id = ?
        ORDER BY s.full_name ASC
      `,
        )
        .all(selectedSessionId) as any[];

      // Load existing agreements if any
      const minutesRecord = db
        .prepare("SELECT agreements FROM minutes WHERE session_id = ?")
        .get(selectedSessionId) as any;
      if (minutesRecord) {
        existingAgreements = JSON.parse(minutesRecord.agreements || "[]");
      }
    }
  }
}
---

<Layout title="Acta de Academia">
  <!-- Encabezado -->
  <div style="margin-bottom: 24px;">
    <span class="overline overline--primary">Operaciones &mdash; Actas</span>
    <h1
      style="font-size: 2.5rem; font-weight: 900; letter-spacing: -0.04em; margin-top: 4px;"
    >
      Acta de Academia
    </h1>
    <p style="font-size: 0.875rem; color: var(--color-ink-2); margin-top: 4px;">
      Selecciona una de las asambleas convocadas para registrar la asistencia de
      los representantes, redactar los acuerdos tomados y generar el documento
      oficial (PDF).
    </p>
  </div>

  <hr class="rule" style="margin-bottom: 32px;" />

  <!-- Selector de Sesión (Las últimas 3 sesiones + Buscar anterior) -->
  <section
    aria-label="Selector de sesiones convocadas"
    style="margin-bottom: 32px;"
  >
    <div
      style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 12px;"
    >
      <span class="overline">Selecciona una sesión de asamblea</span>
      {
        selectedSessionId && (
          <a href="/actas/nuevo" class="link text-xs" style="font-weight: 600;">
            Limpiar Selección
          </a>
        )
      }
    </div>

    <!-- Grid de últimas 3 sesiones convocadas -->
    <div
      style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 16px; margin-bottom: 16px;"
    >
      {
        last3Sessions.length === 0 ? (
          <div class="card p-6 bg-gray-50 border-dashed text-center col-span-3 text-sm text-gray-500">
            No hay sesiones convocadas registradas. Genera un Citatorio para
            comenzar.
          </div>
        ) : (
          last3Sessions.map((session) => {
            const isSelected = selectedSessionId === session.id;
            const statusColors =
              session.status === "completed"
                ? "border-green-600 bg-green-50/10 text-green-800"
                : "border-blue-600 bg-blue-50/10 text-blue-800";

            return (
              <a
                href={`?session=${encodeURIComponent(session.id)}`}
                class={`card text-left transition-all border flex flex-col justify-between h-[130px] ${
                  isSelected
                    ? "border-[#006096] bg-[#006096]/5 ring-1 ring-[#006096]"
                    : "border-gray-200 bg-white hover:border-gray-400"
                }`}
              >
                <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                  <div>
                    <span class="font-mono text-2xs text-gray-500">
                      CONVOCATORIA
                    </span>
                    <h4 style="font-size: 0.9375rem; font-weight: 800; color: var(--color-ink); margin-top: 2px;">
                      {session.id}
                    </h4>
                  </div>
                  <span
                    class={`tag`}
                    style="font-size: 0.5rem; padding: 1px 4px;"
                  >
                    {session.status === "completed"
                      ? "Completada ✔"
                      : "Pendiente ⏳"}
                  </span>
                </div>

                <div
                  style="margin-top: auto; display: flex; justify-content: space-between; align-items: center;"
                  class="text-2xs"
                >
                  <span style="color: var(--color-ink-2); font-weight: 500;">
                    {session.date} · {session.time}
                  </span>
                  {session.career && (
                    <span
                      class="tag tag--secondary"
                      style="font-size: 0.5rem; padding: 0px 4px;"
                    >
                      {session.career}
                    </span>
                  )}
                </div>
              </a>
            );
          })
        )
      }
    </div>

    <!-- Dropdown para buscar sesiones anteriores -->
    {
      olderSessions.length > 0 && (
        <div class="card bg-white p-3 flex flex-col sm:flex-row items-center justify-between gap-3 border-gray-200">
          <span class="text-xs font-bold text-gray-600">
            ¿Buscas una convocatoria anterior?
          </span>
          <div style="display: flex; gap: 8px; width: 100%; max-width: 320px;">
            <select
              id="older-sessions-select"
              class="input bg-white w-full"
              style="height: 38px;"
            >
              <option value="">Selecciona sesión anterior...</option>
              {olderSessions.map((s) => (
                <option value={s.id} selected={selectedSessionId === s.id}>
                  {s.id} ({s.date} · {s.career || "Global"})
                </option>
              ))}
            </select>
            <button
              type="button"
              id="btn-go-older"
              class="btn btn--ghost"
              style="height: 38px; padding: 0 12px; font-size: 10px;"
            >
              Ir
            </button>
          </div>
        </div>
      )
    }
  </section>

  <!-- Formulario Redactar Acta -->
  {
    activeSession ? (
      <ActaForm
        client:load
        sessionId={activeSession.id}
        sessionDate={activeSession.date}
        sessionTime={activeSession.time}
        sessionAgenda={activeSession.agendaParsed}
        invitedStudents={invitedStudents}
        existingAgreements={existingAgreements}
      />
    ) : (
      <div
        class="card p-12 bg-white border-gray-200 text-center flex flex-col items-center gap-4 justify-center"
        style="min-height: 280px;"
      >
        <div style="font-size: 2.5rem; color: var(--color-ink-3);">📋</div>
        <div>
          <h3 class="text-base font-bold text-gray-800">
            Redacción de Acta de Academia
          </h3>
          <p class="text-xs text-gray-500 mt-1 max-w-[420px] mx-auto">
            Por favor, selecciona una de las sesiones convocadas en las tarjetas
            superiores para cargar sus datos y redactar el acta.
          </p>
        </div>
      </div>
    )
  }

  <script>
    // Older sessions select redirect
    const select = document.getElementById(
      "older-sessions-select",
    ) as HTMLSelectElement;
    const btn = document.getElementById("btn-go-older");

    if (btn && select) {
      btn.addEventListener("click", () => {
        const val = select.value;
        if (val) {
          window.location.href = `?session=${encodeURIComponent(val)}`;
        }
      });
    }
  </script>
</Layout>
