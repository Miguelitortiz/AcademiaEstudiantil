---
import Layout from '../layouts/Layout.astro';
import { db } from '../lib/db.js';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login', 302);
}

// Scoped queries
let studentsCount = 0;
let sessionsCount = 0;
let completedCount = 0;
let recentSessions: any[] = [];

if (user.role === 'jefe_carrera') {
  // Count students in this career
  const resStudents = db.prepare('SELECT COUNT(*) as count FROM students WHERE career = ?').get(user.career) as any;
  studentsCount = resStudents ? resStudents.count : 0;

  // Count total sessions in this career
  const resSessions = db.prepare('SELECT COUNT(*) as count FROM sessions WHERE career = ?').get(user.career) as any;
  sessionsCount = resSessions ? resSessions.count : 0;

  // Count completed sessions in this career
  const resCompleted = db.prepare("SELECT COUNT(*) as count FROM sessions WHERE career = ? AND status = 'completed'").get(user.career) as any;
  completedCount = resCompleted ? resCompleted.count : 0;

  // Get recent sessions in this career
  recentSessions = db.prepare('SELECT * FROM sessions WHERE career = ? ORDER BY date DESC, time DESC LIMIT 5').all(user.career) as any[];
} else {
  // Director General - Global queries
  const resStudents = db.prepare('SELECT COUNT(*) as count FROM students').get() as any;
  studentsCount = resStudents ? resStudents.count : 0;

  const resSessions = db.prepare('SELECT COUNT(*) as count FROM sessions').get() as any;
  sessionsCount = resSessions ? resSessions.count : 0;

  const resCompleted = db.prepare("SELECT COUNT(*) as count FROM sessions WHERE status = 'completed'").get() as any;
  completedCount = resCompleted ? resCompleted.count : 0;

  recentSessions = db.prepare('SELECT * FROM sessions ORDER BY date DESC, time DESC LIMIT 5').all() as any[];
}

const pendingCount = sessionsCount - completedCount;
---

<Layout title="Dashboard Principal">
  <!-- Encabezado Asimétrico (Estilo Suizo) -->
  <div style="margin-bottom: 24px;">
    <span class="overline overline--primary">Control General &mdash; Inicio</span>
    <h1 style="font-size: 2.5rem; font-weight: 900; letter-spacing: -0.04em; margin-top: 4px;">
      Panel de Control
    </h1>
    <p style="font-size: 0.875rem; color: var(--color-ink-2); margin-top: 4px;">
      {user.role === 'director' 
        ? 'Bienvenido Director General. Acceso y control global de asambleas de FIME.' 
        : `Bienvenido Jefe de Carrera. Gestión de convocatorias y actas para la carrera de ${user.career}.`}
    </p>
  </div>

  <hr class="rule" style="margin-bottom: 32px;" />

  <!-- Tarjetas de Métricas de Resumen (Sin sombras, bordes de 1px) -->
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 24px; margin-bottom: 40px;">
    <div class="card bg-white flex flex-col justify-between h-[120px]">
      <div>
        <span class="overline">Total Alumnos</span>
        <h2 style="font-size: 2rem; font-weight: 900; color: var(--color-ink); margin-top: 4px;">
          {studentsCount}
        </h2>
      </div>
      <span class="text-2xs text-gray-500">Jefes y subjefes registrados</span>
    </div>

    <div class="card bg-white flex flex-col justify-between h-[120px]">
      <div>
        <span class="overline">Total Citatorios</span>
        <h2 style="font-size: 2rem; font-weight: 900; color: var(--color-secondary); margin-top: 4px;">
          {sessionsCount}
        </h2>
      </div>
      <span class="text-2xs text-gray-500">Convocatorias de sesiones</span>
    </div>

    <div class="card bg-white flex flex-col justify-between h-[120px]">
      <div>
        <span class="overline" style="color: var(--color-primary);">Actas Completadas</span>
        <h2 style="font-size: 2rem; font-weight: 900; color: var(--color-primary); margin-top: 4px;">
          {completedCount}
        </h2>
      </div>
      <span class="text-2xs text-gray-500">Documentos oficiales generados</span>
    </div>

    <div class="card bg-white flex flex-col justify-between h-[120px]">
      <div>
        <span class="overline" style="color: var(--color-error);">Actas Pendientes</span>
        <h2 style="font-size: 2rem; font-weight: 900; color: var(--color-error); margin-top: 4px;">
          {pendingCount}
        </h2>
      </div>
      <span class="text-2xs text-gray-500">Sesiones sin acta registrada</span>
    </div>
  </div>

  <!-- Contenido Principal: Sesiones Recientes -->
  <div class="card bg-white p-6">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
      <div>
        <span class="overline">Registro de Actividad</span>
        <h3 class="text-base font-bold mt-1">Últimas Asambleas Convocadas</h3>
      </div>
      <a href="/citatorios/nuevo" class="btn btn--primary" style="height: 38px; font-size: 11px;">
        + Nueva Sesión
      </a>
    </div>

    {recentSessions.length === 0 ? (
      <div style="text-align: center; padding: 48px 0;" class="text-sm text-gray-500">
        No se han registrado sesiones de asamblea en la base de datos.
      </div>
    ) : (
      <div class="overflow-x-auto scroll">
        <table style="width: 100%; border-collapse: collapse; min-width: 650px;">
          <thead>
            <tr style="border-bottom: 2px solid var(--color-ink); text-align: left;">
              <th scope="col" style="padding: 12px 8px; font-family: var(--font-mono); font-size: 0.5625rem; font-weight: 700; color: var(--color-ink-3); text-transform: uppercase;">ID Sesión</th>
              <th scope="col" style="padding: 12px 8px; font-family: var(--font-mono); font-size: 0.5625rem; font-weight: 700; color: var(--color-ink-3); text-transform: uppercase;">Fecha / Hora</th>
              <th scope="col" style="padding: 12px 8px; font-family: var(--font-mono); font-size: 0.5625rem; font-weight: 700; color: var(--color-ink-3); text-transform: uppercase;">Carrera</th>
              <th scope="col" style="padding: 12px 8px; font-family: var(--font-mono); font-size: 0.5625rem; font-weight: 700; color: var(--color-ink-3); text-transform: uppercase;">Convocados</th>
              <th scope="col" style="padding: 12px 8px; font-family: var(--font-mono); font-size: 0.5625rem; font-weight: 700; color: var(--color-ink-3); text-transform: uppercase;">Estado</th>
              <th scope="col" style="padding: 12px 8px; font-family: var(--font-mono); font-size: 0.5625rem; font-weight: 700; color: var(--color-ink-3); text-transform: uppercase; text-align: right;">Acción</th>
            </tr>
          </thead>
          <tbody>
            {recentSessions.map((session) => (
              <tr style="border-bottom: 1px solid var(--color-rule); transition: background-color 80ms;" class="hover:bg-muted">
                <td style="padding: 12px 8px; font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; color: var(--color-ink);">{session.id}</td>
                <td style="padding: 12px 8px; font-size: 0.8125rem; color: var(--color-ink-2);">{session.date} a las {session.time} Hrs</td>
                <td style="padding: 12px 8px; font-size: 0.8125rem; color: var(--color-ink-2);">{session.career || 'Todas'}</td>
                <td style="padding: 12px 8px; font-size: 0.8125rem; color: var(--color-ink-2);">{session.role_type}</td>
                <td style="padding: 12px 8px;">
                  <span class={`tag ${session.status === 'completed' ? 'tag--primary' : 'tag--secondary'}`} style="font-size: 0.5rem; padding: 1px 4px;">
                    {session.status === 'completed' ? 'Completado' : 'Convocado'}
                  </span>
                </td>
                <td style="padding: 12px 8px; text-align: right;">
                  {session.status === 'completed' ? (
                    <div style="display: flex; gap: 8px; justify-content: flex-end;">
                      <a href={`/api/pdf?session_id=${encodeURIComponent(session.id)}`} target="_blank" rel="noopener noreferrer" class="link" style="font-size: 0.75rem; font-weight: 600;">
                        Descargar PDF
                      </a>
                      <span style="color: var(--color-rule);">|</span>
                      <a href={`/actas/print?session_id=${encodeURIComponent(session.id)}`} class="link text-gray-600 hover:text-black" style="font-size: 0.75rem;">
                        Ver Imprimible
                      </a>
                    </div>
                  ) : (
                    <a href={`/actas/nuevo?session=${encodeURIComponent(session.id)}`} class="btn btn--ghost" style="height: 28px; padding: 0 10px; font-size: 10px; border-radius: 4px;">
                      Redactar Acta
                    </a>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</Layout>
